void code32() {
    int a, b, gcd = 1;
    cin >> a >> b;
    for(int i = 1; i <= a && i <= b; i++)
        if(a % i == 0 && b % i == 0) gcd = i;
    cout << "GCD = " << gcd << endl;
}

// 33. LCM
void code33() {
    int a, b;
    cin >> a >> b;
    int max = (a > b) ? a : b;
    while(true) {
        if(max % a == 0 && max % b == 0) {
            cout << "LCM = " << max << endl;
            break;
        }
        max++;
    }
}

