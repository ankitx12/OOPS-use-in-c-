void code25() {
    int n, rev = 0;
    cin >> n;
    while(n != 0) {
        rev = rev * 10 + n % 10;
        n /= 10;
    }
    cout << "Reverse = " << rev << endl;
}

// 26. Palindrome Number
void code26() {
    int n, temp, rev = 0;
    cin >> n;
    temp = n;
    while(n != 0) {
        rev = rev * 10 + n % 10;
        n /= 10;
    }
    cout << (temp == rev ? "Palindrome" : "Not Palindrome") << endl;
}

// 27. Armstrong Number
void code27() {
    int n, temp, sum = 0, rem;
    cin >> n;
    temp = n;
    while(n != 0) {
        rem = n % 10;
        sum += rem * rem * rem;
        n /= 10;
    }
    cout << (temp == sum ? "Armstrong" : "Not Armstrong") << endl;
}

