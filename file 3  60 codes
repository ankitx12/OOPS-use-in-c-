// 57. Sort Array Ascending
void code57() {
    int arr[5] = {5, 2, 8, 1, 3};
    for(int i = 0; i < 5; i++) {
        for(int j = i + 1; j < 5; j++) {
            if(arr[i] > arr[j]) {
                int temp = arr[i];
                arr[i] = arr[j];
                arr[j] = temp;
            }
        }
    }
    for(int i = 0; i < 5; i++)
        cout << arr[i] << " ";
    cout << endl;
}

