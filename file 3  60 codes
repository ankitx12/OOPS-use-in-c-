// 49. Hollow Square Pattern
void code49() {
    int n = 5;
    for(int i = 1; i <= n; i++) {
        for(int j = 1; j <= n; j++) {
            if(i == 1 || i == n || j == 1 || j == n)
                cout << "* ";
            else
                cout << "  ";
        }
        cout << endl;
    }
}

// 50. Pyramid Pattern
void code50() {
    int n = 5;
    for(int i = 1; i <= n; i++) {
        for(int j = 1; j <= n - i; j++)
            cout << " ";
        for(int k = 1; k <= (2 * i - 1); k++)
            cout << "*";
        cout << endl;
    }
}

