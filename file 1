27. Check Armstrong Number
#include <iostream>using namespace std;int main() {    int n, temp, sum = 0, rem;    cin >> n;    temp = n;    while(n != 0) {        rem = n % 10;        sum += rem * rem * rem;        n /= 10;    }    if(temp == sum)        cout << "Armstrong";    else        cout << "Not Armstrong";    return 0;}

