Calculator Using Switch
#include <iostream>
using namespace std;

int main() {
    int a = 10, b = 5;
    char op = '+';

    switch(op) {
        case '+': cout << a + b; break;
        case '-': cout << a - b; break;
        case '*': cout << a * b; break;
        case '/': cout << a / b; break;
        default: cout << "Invalid";
    }
    return 0;
}

Check Prime Number
#include <iostream>
using namespace std;

int main() {
    int n, i, count = 0;
    cin >> n;

    for(i = 1; i <= n; i++) {
        if(n % i == 0)
            count++;
    }

    if(count == 2)
        cout << "Prime";
    else
        cout << "Not Prime";

    return 0;
}


